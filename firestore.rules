rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // 1. User Profile Rules
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.userId == userId 
          && data.email is string && data.email.size() <= 256
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 20))
          && (data.address == null || (data.address is string && data.address.size() <= 500))
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
        && isValidUserProfile(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'address', 'updatedAt']);
    }

    // 2. Order Rules
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.orderId == orderId
          && data.userId is string && data.userId == request.auth.uid
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total >= 0
          && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
          && data.paymentMethod is string && data.paymentMethod.size() <= 50
          && data.address is string && data.address.size() <= 500
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn()
        && isValidOrder(incoming())
        && incoming().orderId == orderId
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;

      allow update: if (isOwner(existing().userId)
        && existing().status == 'pending'
        && incoming().status == 'cancelled'
        && incoming().orderId == existing().orderId
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }
  }
}
