rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'flavmbish@gmail.com' ||
        request.auth.token.email == 'flavmbish@icloud.com' ||
        request.auth.token.email == 'flavien.mbishibishi@a2sv.org' ||
        request.auth.token.email == 'test.admin@simba.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // 1. User Profile Rules
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.userId == userId 
          && data.email is string && data.email.size() <= 256
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 20))
          && (data.address == null || (data.address is string && data.address.size() <= 500))
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
        && isValidUserProfile(incoming())
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      
      allow update: if (isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'address', 'updatedAt']))
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['isAdmin']));
    }

    // 2. Order Rules
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.orderId == orderId
          && data.userId is string && data.userId == request.auth.uid
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total >= 0
          && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
          && data.paymentMethod is string && data.paymentMethod.size() <= 50
          && data.address is string && data.address.size() <= 500
          && data.createdAt is timestamp;
      }

      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified()
        && isValidOrder(incoming())
        && incoming().orderId == orderId
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;

      allow update: if (isOwner(existing().userId)
        && existing().status == 'pending'
        && incoming().status == 'cancelled'
        && incoming().orderId == existing().orderId
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    // 3. Product Rules
    match /products/{productId} {
      function isValidProduct(data) {
        return data.id is string
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && (data.costPrice == null || (data.costPrice is number && data.costPrice >= 0))
          && data.category is string && data.category.size() <= 100
          && data.stockCount is number
          && (data.warehouseStockCount == null || data.warehouseStockCount is number)
          && (data.barcode == null || (data.barcode is string && data.barcode.size() <= 100));
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if (isAdmin() && isValidId(productId))
        || (isVerified() && isValidId(productId)
            && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'reviewCount'])
            && incoming().reviewCount == existing().reviewCount + 1
            && isValidProduct(incoming())
           );
      allow delete: if isAdmin() && isValidId(productId);
    }

    // 4. Branch Review Rules
    match /branchReviews/{reviewId} {
      function isValidBranchReview(data) {
        return data.userId == request.auth.uid
          && data.branchId is string && data.branchId.size() > 0
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && (data.comment.size() == 0 || data.comment.size() <= 2000)
          && data.createdAt is timestamp;
      }

      allow read: if true;
      allow create: if isVerified() && isValidBranchReview(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isAdmin() || (isOwner(existing().userId));
    }

    // 5. Product Review Rules
    match /productReviews/{reviewId} {
      function isValidProductReview(data) {
        return data.userId == request.auth.uid
          && data.productId is string && data.productId.size() > 0 && data.productId.size() <= 64
          && data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && (data.comment.size() >= 1 && data.comment.size() <= 2000)
          && data.createdAt is timestamp;
      }

      allow read: if true;
      allow create: if isVerified() && isValidId(reviewId)
        && isValidProductReview(incoming()) 
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/products/$(incoming().productId));
      
      allow update, delete: if (isAdmin() && isValidId(reviewId)) || (isOwner(existing().userId) && isValidId(reviewId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment'])
        && isValidProductReview(incoming())
        && incoming().userId == existing().userId
        && incoming().productId == existing().productId
        && incoming().createdAt == existing().createdAt
      ));
    }

    // 6. Wishlist Rules
    match /users/{userId}/wishlist/{productId} {
      function isValidWishlistItem(data) {
        return data.userId == userId
          && data.productId == productId
          && data.addedAt is timestamp;
      }

      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
        && isValidWishlistItem(incoming())
        && isValidId(productId)
        && incoming().addedAt == request.time;
      
      allow delete: if isOwner(userId);
    }

    // 7. Supermarket Management Rules (Admin Only)
    match /suppliers/{supplierId} {
      allow read, write: if isAdmin();
    }
    match /purchaseOrders/{orderId} {
      allow read, write: if isAdmin();
    }
    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /inventoryAlerts/{alertId} {
      allow read, write: if isAdmin();
    }
  }
}
