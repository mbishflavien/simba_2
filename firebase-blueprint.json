{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the user" },
        "displayName": { "type": "string", "description": "The name shown for the user" },
        "email": { "type": "string", "description": "The user's email address" },
        "phoneNumber": { "type": "string", "description": "The user's contact number" },
        "address": { "type": "string", "description": "The user's delivery address in Kigali" },
        "isAdmin": { "type": "boolean", "description": "Whether the user has administrative privileges" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated" }
      },
      "required": ["userId", "email", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Records a customer's purchase",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "Unique identifier for the order" },
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of items purchased" },
        "total": { "type": "number", "description": "Total amount paid" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"], "description": "Current status of the order" },
        "paymentMethod": { "type": "string", "description": "Method used for payment (e.g., MoMo, card, cash)" },
        "address": { "type": "string", "description": "Delivery address or pickup instructions" },
        "pickupBranch": { "type": "string", "description": "The specific branch selected for cash on pickup" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed" }
      },
      "required": ["orderId", "userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Details about a product in the supermarket inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Retail price in RWF" },
        "costPrice": { "type": "number", "description": "Cost price in RWF for profit calculation" },
        "category": { "type": "string", "description": "Product category" },
        "inStock": { "type": "boolean", "description": "Whether the product is currently available" },
        "stockCount": { "type": "number", "description": "Current quantity in store stock" },
        "warehouseStockCount": { "type": "number", "description": "Current quantity in warehouse" },
        "lowStockThreshold": { "type": "number", "description": "Threshold for low stock alerts" },
        "barcode": { "type": "string", "description": "Barcode or QR code" },
        "expiryDate": { "type": "string", "format": "date", "description": "Expiry date for perishables" },
        "supplierId": { "type": "string", "description": "Primary supplier ID" },
        "image": { "type": "string", "description": "URL to the product image" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., 1kg, 500ml)" },
        "rating": { "type": "number", "description": "Average rating" },
        "reviewCount": { "type": "number", "description": "Total reviews" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the product was last updated" }
      },
      "required": ["id", "name", "price", "costPrice", "category", "stockCount", "warehouseStockCount", "image", "createdAt", "updatedAt"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Information about product suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "category": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "active"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "description": "An order sent to a supplier for restock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "totalCost": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "ordered", "received", "cancelled"] },
        "expectedDelivery": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "supplierId", "items", "totalCost", "status", "createdAt"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Active discounts and campaigns",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["percentage", "fixed", "buy1get1"] },
        "value": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "applicableCategories": { "type": "array" },
        "applicableProducts": { "type": "array" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "type", "value", "startDate", "endDate", "isActive"]
    },
    "StaffMember": {
      "title": "Staff Member",
      "description": "Employee performance and shifts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["manager", "cashier", "inventory", "cleaner"] },
        "phone": { "type": "string" },
        "shiftStatus": { "type": "string", "enum": ["on_duty", "off_duty", "break"] },
        "lastClockIn": { "type": "string", "format": "date-time" },
        "performanceScore": { "type": "number" }
      },
      "required": ["id", "name", "role", "shiftStatus"]
    },
    "InventoryAlert": {
      "title": "Inventory Alert",
      "description": "Actionable notifications for managers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["low_stock", "near_expiry", "anomaly"] },
        "productId": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "productId", "message", "severity", "isRead", "createdAt"]
    },
    "BranchReview": {
      "title": "Branch Review",
      "description": "A user review for a specific supermarket branch",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string", "description": "Unique ID for the review" },
        "userId": { "type": "string", "description": "ID of the user who wrote the review" },
        "userDisplayName": { "type": "string", "description": "Name of the user for display" },
        "branchId": { "type": "string", "description": "The specific branch being reviewed" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "The text of the review" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was submitted" }
      },
      "required": ["reviewId", "userId", "branchId", "rating", "comment", "createdAt"]
    },
    "ProductReview": {
      "title": "Product Review",
      "description": "A user review for a specific product",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the review" },
        "productId": { "type": "string", "description": "The specific product being reviewed" },
        "userId": { "type": "string", "description": "ID of the user who wrote the review" },
        "userName": { "type": "string", "description": "Name of the user for display" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "The text of the review" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was submitted" }
      },
      "required": ["id", "productId", "userId", "rating", "comment", "createdAt"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A product saved by a user for future interest",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the saved product" },
        "userId": { "type": "string", "description": "The ID of the user who saved it" },
        "addedAt": { "type": "string", "format": "date-time", "description": "When the item was added to the wishlist" }
      },
      "required": ["productId", "userId", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profile documents"
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "User's personal saved products list"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Historical records of all customer orders"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory of products available for sale"
    },
    "/branchReviews/{reviewId}": {
      "schema": "BranchReview",
      "description": "Customer reviews and ratings for specific branches"
    },
    "/productReviews/{reviewId}": {
      "schema": "ProductReview",
      "description": "Customer reviews and ratings for specific products"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "List of active and inactive suppliers"
    },
    "/purchaseOrders/{orderId}": {
      "schema": "PurchaseOrder",
      "description": "Stock replenishment records linked to suppliers"
    },
    "/staff/{staffId}": {
      "schema": "StaffMember",
      "description": "Employee performance and attendance tracking"
    },
    "/promotions/{promoId}": {
      "schema": "Promotion",
      "description": "Marketing and dynamic pricing rules"
    },
    "/inventoryAlerts/{alertId}": {
      "schema": "InventoryAlert",
      "description": "Actionable notifications for managers regarding stock and performance"
    }
  }
}
